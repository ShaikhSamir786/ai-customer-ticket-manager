# Set default behavior to automatically normalize line endings to LF
* text=auto

# Explicitly declare text files
*.json text
*.yml text
*.yaml text
*.md text
*.txt text

# Declare files that will always have CRLF line endings on checkout
*.bat text eol=crlf
*.cmd text eol=crlf

# Declare files that will always have LF line endings on checkout
*.sh text eol=lf

# Denote all files that are truly binary and should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary

# Handle TypeScript/JavaScript files
*.ts text
*.tsx text
*.js text
*.jsx text
*.cjs text
*.mjs text

# Lock files
package-lock.json merge=npm
yarn.lock merge=yarn
pnpm-lock.yaml merge=npm