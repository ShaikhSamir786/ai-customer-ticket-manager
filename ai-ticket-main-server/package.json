{
  "name": "@ai-ticket/main-server",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn src/index.ts",
    "build": "tsc && copyfiles -u 1 \"src/graphql/modules/**/*.graphql\" dist/",
    "start": "node dist/index.js",
    "lint": "echo 'lint ok'",
    "typecheck": "tsc --noEmit",
    "clean": "if exist dist rmdir /s /q dist"
  },
  "dependencies": {
    "@ai-ticket/shared-lib": "file:../ai-ticket-shared-lib",
    "@apollo/server": "^5.5.1",
    "@as-integrations/express4": "^1.1.2",
    "axios": "^1.7.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "graphql": "^16.14.1",
    "graphql-tag": "^2.12.6",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^22.0.0",
    "copyfiles": "^2.4.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.0"
  }
}
